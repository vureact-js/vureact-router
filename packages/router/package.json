{
  "name": "@vureact/router",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/cjs/vureact-router.cjs",
  "module": "./dist/esm/vureact-router.mjs",
  "types": "./dist/types/vureact-router.d.ts",
  "author": "Ryan John",
  "license": "MIT",
  "description": "Vue Router 4.x Adapter for React 18+ (Encapsulated on React Router DOM 7.9+)",
  "keywords": [
    "react",
    "vureact-router",
    "react-router",
    "react-router-dom",
    "react-vue-router-adapter"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/vureact-router.d.ts",
      "import": "./dist/esm/vureact-router.mjs",
      "require": "./dist/cjs/vureact-router.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://router-vureact.vercel.app/en",
  "repository": {
    "type": "git",
    "url": "https://github.com/vureact-js/vureact-router.git",
    "directory": "packages/router"
  },
  "bugs": {
    "url": "https://github.com/vureact-js/vureact-router/issues"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && rollup -c --bundleConfigAsCjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "react-router-dom": ">=7.9.0"
  },
  "dependencies": {}
}