{
  "name": "@vureact/router",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/cjs/vureact-router.cjs",
  "module": "./dist/esm/vureact-router.mjs",
  "types": "./dist/types/vureact-router.d.ts",
  "author": "Ryan John",
  "license": "MIT",
  "description": "Vue Router 4.x style routing library for React 18+ with full TypeScript support, navigation guards, async components, and familiar API for Vue developers transitioning to React.",
  "keywords": [
    "react",
    "react-router",
    "react-router-dom",
    "vue-router",
    "router",
    "routing",
    "navigation",
    "react-vue-like",
    "vureact-router",
    "react-vue-router-adapter",
    "typescript",
    "navigation-guards",
    "async-components",
    "code-splitting"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/vureact-router.d.ts",
      "import": "./dist/esm/vureact-router.mjs",
      "require": "./dist/cjs/vureact-router.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://router-vureact.vercel.app/en",
  "repository": {
    "type": "git",
    "url": "https://github.com/vureact-js/vureact-router.git",
    "directory": "tree/master/packages/router"
  },
  "bugs": {
    "url": "https://github.com/vureact-js/vureact-router/issues"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && rollup -c --bundleConfigAsCjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "react-router-dom": ">=7.9.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=16.0.0"
  }
}